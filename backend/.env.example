# =============================================================================
# 🔐 CONFIGURACIÓN DE ENTORNO - ALLTURA REPORTS
# =============================================================================
# IMPORTANTE: Este archivo es una PLANTILLA. NO contiene valores reales.
# Para configurar tu entorno:
#   1. Copia este archivo: cp .env.example .env
#   2. Genera secretos seguros con: npm run generate-secret
#   3. NUNCA commitees el archivo .env al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------------------------------------------
DB_USER=alltura_user
DB_HOST=localhost
DB_NAME=alltura_reports_db
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_32_CARACTERES_MIN
DB_PORT=5432

# -----------------------------------------------------------------------------
# JWT Authentication (CRÍTICO - GENERAR SECRETOS CRIPTOGRÁFICAMENTE SEGUROS)
# -----------------------------------------------------------------------------
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUISITOS:
#   - Mínimo 64 caracteres hexadecimales (256 bits)
#   - Debe ser diferente en cada entorno (dev, staging, prod)
#   - Rotar cada 90 días
JWT_SECRET=CAMBIAR_POR_SECRET_SEGURO_64_CARACTERES_HEX_MIN
JWT_REFRESH_SECRET=CAMBIAR_POR_REFRESH_SECRET_DIFERENTE_64_CARACTERES_HEX_MIN

# -----------------------------------------------------------------------------
# Redis (Token Blacklist & Rate Limiting)
# -----------------------------------------------------------------------------
# Para desarrollo local: redis://localhost:6379
# Para producción: redis://usuario:password@host:puerto
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Google Cloud Storage (Almacenamiento de archivos)
# -----------------------------------------------------------------------------
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your/service-account-key.json

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID Keys)
# -----------------------------------------------------------------------------
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui

# -----------------------------------------------------------------------------
# Entorno y Configuración General
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# URL del cliente (para CORS)
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging y Monitoreo
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# =============================================================================
# INSTRUCCIONES DE SEGURIDAD
# =============================================================================
#
# ✅ HACER:
#   - Generar secretos únicos y aleatorios para cada entorno
#   - Usar gestores de secretos (AWS Secrets Manager, HashiCorp Vault)
#   - Rotar secretos periódicamente (cada 90 días)
#   - Usar diferentes secretos para dev, staging y producción
#
# ❌ NO HACER:
#   - Usar contraseñas débiles o predecibles
#   - Reutilizar secretos entre entornos
#   - Commitear el archivo .env al repositorio
#   - Compartir secretos por email o Slack
#
# =============================================================================
