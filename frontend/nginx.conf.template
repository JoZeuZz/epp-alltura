server {
  listen 80;
  server_name _;

  server_tokens off;

  # Allow larger uploads for asset images
  client_max_body_size 25m;
  client_body_timeout 60s;
  send_timeout 180s;

  # Gzip compression for faster asset delivery
  gzip on;
  gzip_comp_level 6;
  gzip_min_length 1024;
  gzip_proxied any;
  gzip_vary on;
  gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/manifest+json
    application/xml
    application/xml+rss
    image/svg+xml;

  root /usr/share/nginx/html;
  index index.html;

  # Long-term cache for hashed build assets
  location /assets/ {
    add_header Cache-Control "public, max-age=31536000, immutable" always;
    try_files $uri =404;
  }

  # Don't serve source maps in production
  location ~* \.map$ {
    return 404;
  }

  # Ensure HTML and critical manifests are always fresh
  location = /index.html {
    add_header Cache-Control "no-store" always;
  }

  location = /manifest.json {
    add_header Cache-Control "no-cache, no-store, must-revalidate" always;
  }

  location = /sw.js {
    add_header Cache-Control "no-cache, no-store, must-revalidate" always;
  }

  location = /api {
    return 301 /api/;
  }

  # Proxy API requests to backend service. BACKEND_URL defaults to http://backend:5000
  location /api/ {
    proxy_pass ${BACKEND_URL}/api/;
    proxy_connect_timeout 30s;
    proxy_read_timeout 180s;
    proxy_send_timeout 180s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_redirect off;
  }

  location = /uploads {
    return 301 /uploads/;
  }

  location /uploads/ {
    proxy_pass ${BACKEND_URL}/uploads/;
    proxy_connect_timeout 30s;
    proxy_read_timeout 180s;
    proxy_send_timeout 180s;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_redirect off;
  }

  # SPA fallback
  location / {
    try_files $uri $uri/ /index.html;
  }
}
